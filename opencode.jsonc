{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "pyright": {"disabled": true},
    "uv-pyright": {
      "extensions": [".py", ".pyi"],
      "command": ["uv", "run", "pyright-langserver",  "--stdio"]
    }
  },
  "model": "openrouter/deepseek/deepseek-v4-flash",
  "small_model": "openrouter/minimax/minimax-m2.7",
  "mode": {
    "build": {
      "temperature": 0.1
    },
    "plan": {
      "temperature": 0.1
    }
  },
  "permission": {
    "bash": {
      "git commit *": "deny",
      "git checkout *": "deny",
      "git reset *": "deny",
      "git rm*": "deny",
      "git cherry-pick *": "deny",
      "rm *": "deny",
      "rm scratch/*": "allow",
      "rm -r scratch/*": "allow",
      "rm -fr scratch/*": "allow"
    }
  },
  "mcp": {
    "ddg": {
      "type": "local",
      "command": ["uvx", "duckduckgo-mcp-server"],
      "enabled": true
    }
  }
}
